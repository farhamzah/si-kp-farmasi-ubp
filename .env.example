APP_NAME="SI-KP Farmasi UBP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
KP_AUTH_MODE=legacy
KP_MASTER_DATA_READ_MODE=legacy
KP_CORE_HTTP_ENABLED=false
KP_CORE_BASE_URL=
KP_CORE_PROFILE_URL=
KP_CORE_APP_CODE=kp-farmasi
KP_CORE_CLIENT_ID=
KP_CORE_CLIENT_SECRET=
KP_CORE_TIMEOUT=5
KP_CORE_CONNECT_TIMEOUT=3
KP_CORE_VERIFY_SSL=true
KP_CORE_READ_MODE=legacy
KP_CORE_FAIL_SILENTLY=true
# Production: set APP_ENV=production, APP_DEBUG=false, and APP_URL to the real HTTPS domain.

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sikp_farmasi_ubp
DB_USERNAME=root
DB_PASSWORD=

CORE_DB_CONNECTION=mysql
CORE_DB_HOST=127.0.0.1
CORE_DB_PORT=3306
CORE_DB_DATABASE=core_farmasi_ubp
CORE_DB_USERNAME=root
CORE_DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
# Production HTTPS: set SESSION_SECURE_COOKIE=true and adjust SESSION_DOMAIN when needed.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
# Production: configure SMTP/mail service only when notification email is enabled.
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
